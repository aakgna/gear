{
	"expo": {
		"name": "Kracked",
		"slug": "gear",
		"version": "1.0.3",
		"orientation": "portrait",
		"icon": "./assets/images/Kracked_logo.png",
		"scheme": "kracked",
		"userInterfaceStyle": "light",
		"newArchEnabled": true,
		"ios": {
			"supportsTablet": true,
			"bundleIdentifier": "com.aakgna.gear",
			"googleServicesFile": "./GoogleService-Info.plist",
			"buildNumber": "2",
			"usesAppleSignIn": true,
			"appleTeamId": "2W9F399FQ7",
			"infoPlist": {
				"ITSAppUsesNonExemptEncryption": false
			},
			"entitlements": {
				"aps-environment": "production"
			}
		},
		"android": {
			"versionCode": 1,
			"package": "com.aakgna.gear",
			"googleServicesFile": "./google-services.json",
			"permissions": ["INTERNET"]
		},
		"web": {
			"bundler": "metro",
			"output": "static",
			"favicon": "./_transparent.png"
		},
		"plugins": [
			"expo-router",
			"@react-native-firebase/app",
			"@react-native-firebase/auth",
			[
				"expo-build-properties",
				{
					"android": {
						"compileSdkVersion": 34,
						"targetSdkVersion": 34,
						"minSdkVersion": 21
					},
					"ios": {
						"useFrameworks": "static"
					}
				}
			]
		],
		"experiments": {
			"typedRoutes": true
		},
		"extra": {
			"router": {
				"origin": false
			},
			"eas": {
				"projectId": "a97502dd-accf-434a-b5c3-f652a0af0a56"
			}
		}
	}
}
