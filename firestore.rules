rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    function isAuthenticated() {
      return request.auth != null;
    }

    function isOwner(userId) {
      return request.auth != null && request.auth.uid == userId;
    }

    // ──────────────────────────────────────────────────────────────
    // USERS
    // ──────────────────────────────────────────────────────────────
    match /users/{userId} {
      // Any authenticated user can read profiles (search, social graph, DMs)
      allow read: if isAuthenticated();

      // Only owner can create or delete their own document
      allow create, delete: if isOwner(userId);

      // Owner can do any update; other authenticated users may only touch
      // social counter / moderation fields (follow counts, strike count,
      // unread notification count) — never sensitive fields like email or bio.
      allow update: if isAuthenticated() && (
        isOwner(userId) ||
        request.resource.data.diff(resource.data).affectedKeys()
          .hasOnly(['followerCount', 'followingCount', 'gameStrikeCount',
                    'unreadNotificationCount', 'updatedAt'])
      );

      // Game history — strictly private
      match /gameHistory/{gameId} {
        allow read, write: if isOwner(userId);
      }

      // Created-game references — publicly readable (profile pages)
      // Any authenticated user may update only the 'visible' field
      // (moderation cascade when a game is hidden by reports)
      match /createdGames/{gameId} {
        allow read: if isAuthenticated();
        allow create, delete: if isOwner(userId);
        allow update: if isAuthenticated() && (
          isOwner(userId) ||
          request.resource.data.diff(resource.data).affectedKeys().hasOnly(['visible'])
        );
      }

      // Liked games — publicly readable; owner creates
      // Any authenticated user may update only 'visible' (moderation cascade)
      // Any authenticated user may delete (game-creator cascade delete on game removal)
      match /liked/{puzzleId} {
        allow read: if isAuthenticated();
        allow create: if isOwner(userId);
        allow update: if isAuthenticated() && (
          isOwner(userId) ||
          request.resource.data.diff(resource.data).affectedKeys().hasOnly(['visible'])
        );
        allow delete: if isAuthenticated();
      }

      // Following list — anyone reads (social graph)
      // Owner manages their list; the followed user may also delete their own
      // entry from a follower's list (account-deletion cascade)
      match /following/{targetUserId} {
        allow read: if isAuthenticated();
        allow write: if isOwner(userId) || isOwner(targetUserId);
      }

      // Followers list — anyone reads
      // Owner manages; the follower may write/delete their own entry
      // (followUser / unfollowUser write to the target's followers subcollection)
      match /followers/{followerUserId} {
        allow read: if isAuthenticated();
        allow write: if isOwner(userId) || isOwner(followerUserId);
      }

      // Blocked users — strictly private; owner manages
      match /blocked/{blockedUserId} {
        allow read, write: if isOwner(userId);
      }

      // BlockedBy — owner reads; the blocker writes their own entry
      // (blockUser / unblockUser write to the blocked user's blockedBy subcollection)
      match /blockedBy/{blockerUserId} {
        allow read: if isOwner(userId);
        allow write: if isOwner(userId) || isOwner(blockerUserId);
      }

      // Conversation refs (denormalized) — owner reads
      // Any authenticated user may write: sendMessage updates both participants'
      // refs, and createConversation sets both before the caller is owner of one
      match /conversations/{conversationId} {
        allow read: if isOwner(userId);
        allow write: if isAuthenticated();
      }

      // Notifications — owner reads their own
      // Any authenticated user may create or update:
      //   • followUser creates a follow notification for the target
      //   • likeGame / addGameComment / likeGameComment create/update grouped
      //     notifications on the recipient's subcollection
      //   • unlikeGame / unlikeGameComment update the recipient's notification
      // Any authenticated user may delete:
      //   • account-deletion cascade removes notifications the deleted user created
      // Authenticated users may also read another user's notifications when
      // they are the sender — required for account-deletion cleanup to locate
      // and remove/update notifications they created in other users' feeds.
      match /notifications/{notificationId} {
        allow read, write: if isAuthenticated();
      }

      // Reports — owner submits and reads; immutable after creation
      match /reports/{reportId} {
        allow read: if isOwner(userId);
        allow create: if isOwner(userId);
        allow update, delete: if false;
      }

      // Developer games (kracked_web developer portal — client-side SDK calls)
      match /developerGames/{gameId} {
        allow read, write: if isOwner(userId);
      }
    }

    // ──────────────────────────────────────────────────────────────
    // GAMES  (3-level hierarchy: gameType / difficulty / gameId)
    // ──────────────────────────────────────────────────────────────
    match /games/{gameType}/{difficulty}/{gameId} {
      allow read: if isAuthenticated();
      allow create: if isAuthenticated();

      // Any authenticated user may update:
      //   • Stats fields (completions, skips, likeCount, commentCount, etc.)
      //   • downVote and visible (moderation via reportGame)
      allow update: if isAuthenticated();

      // Only the game creator may delete the game document itself
      allow delete: if isAuthenticated() && request.auth.uid == resource.data.uid;

      // Likes — only the owner of the like document may create/update it;
      // any authenticated user may delete (game-creator cascade on deleteGame)
      match /likes/{likeUserId} {
        allow read: if isAuthenticated();
        allow create, update: if isOwner(likeUserId);
        allow delete: if isAuthenticated();
      }

      // Comments — anyone may read/create
      // Update: comment author, game creator (for moderation), or any authenticated
      //   user touching only 'likedBy' and 'likes' (likeGameComment / unlikeGameComment)
      // Delete: comment author or game creator (cascade deleteGame)
      match /comments/{commentId} {
        allow read: if isAuthenticated();
        allow create: if isAuthenticated();
        allow update: if isAuthenticated() && (
          request.auth.uid == resource.data.userId ||
          request.auth.uid == get(/databases/$(database)/documents/games/$(gameType)/$(difficulty)/$(gameId)).data.uid ||
          request.resource.data.diff(resource.data).affectedKeys().hasOnly(['likedBy', 'likes'])
        );
        allow delete: if isAuthenticated() && (
          request.auth.uid == resource.data.userId ||
          request.auth.uid == get(/databases/$(database)/documents/games/$(gameType)/$(difficulty)/$(gameId)).data.uid
        );
      }
    }

    // Catch-all for any other path under /games (legacy paths, collection-level reads)
    // Grants read to authenticated users; write is never granted here so the
    // specific rules above remain authoritative for writes.
    match /games/{document=**} {
      allow read: if isAuthenticated();
      allow write: if false;
    }

    // ──────────────────────────────────────────────────────────────
    // USERNAMES  (username → userId index for uniqueness checks)
    // ──────────────────────────────────────────────────────────────
    match /usernames/{username} {
      allow read: if isAuthenticated();
      // Creator must be claiming their own userId
      allow create: if isAuthenticated() && request.resource.data.userId == request.auth.uid;
      // Only the owner of the username entry may update or release it
      allow update, delete: if isAuthenticated() && resource.data.userId == request.auth.uid;
    }

    // ──────────────────────────────────────────────────────────────
    // GAME ADDITION  (user-submitted game ideas / suggestions)
    // ──────────────────────────────────────────────────────────────
    match /gameAddition/{ideaId} {
      allow read: if false;
      allow create: if isAuthenticated();
      allow update, delete: if false;
    }

    // ──────────────────────────────────────────────────────────────
    // CONVERSATIONS  (direct messages)
    // ──────────────────────────────────────────────────────────────
    match /conversations/{conversationId} {
      allow read: if isAuthenticated() &&
        request.auth.uid in resource.data.participants;
      allow create: if isAuthenticated() &&
        request.auth.uid in request.resource.data.participants;
      allow update, delete: if isAuthenticated() &&
        request.auth.uid in resource.data.participants;

      // Messages — participants only
      match /messages/{messageId} {
        allow read, write: if isAuthenticated() &&
          request.auth.uid in
            get(/databases/$(database)/documents/conversations/$(conversationId)).data.participants;
      }
    }

    // ──────────────────────────────────────────────────────────────
    // VERSION  (app version metadata — read-only for clients)
    // ──────────────────────────────────────────────────────────────
    match /version/{docId} {
      allow read: if isAuthenticated();
      allow write: if false;
    }

    // ──────────────────────────────────────────────────────────────
    // DEVELOPER SIGNUPS  (gear app developer-interest list)
    // ──────────────────────────────────────────────────────────────
    match /developer/{userId} {
      allow read, write: if isOwner(userId);
    }

    // ──────────────────────────────────────────────────────────────
    // AI CODE  (kracked_web — only written server-side via Admin SDK)
    // Admin SDK bypasses security rules, so client access is denied.
    // ──────────────────────────────────────────────────────────────
    match /ai_code/{compositeId} {
      allow read, write: if false;
    }

    // ──────────────────────────────────────────────────────────────
    // PUZZLES  (kracked_web published puzzles — Admin SDK only)
    // Clients may read published puzzles; writes go through the server.
    // ──────────────────────────────────────────────────────────────
    match /puzzles/{puzzleId} {
      allow read: if isAuthenticated();
      allow write: if false;
    }

    // ──────────────────────────────────────────────────────────────
    // NOTIFICATIONS  (explicit full path — account-deletion cleanup)
    // Declared at top level so the full path is unambiguous.
    // Any authenticated user can read/write — needed so a deleting
    // user can locate and remove notifications they sent to others.
    // ──────────────────────────────────────────────────────────────
    match /users/{userId}/notifications/{notificationId} {
      allow read, write: if isAuthenticated();
    }

  }
}